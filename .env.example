# Public site URL used to build the same-origin Typesense proxy endpoint.
# Usually keep the production custom domain here.
PUBLIC_SITE_URL=https://word.lovejade.cn

# Starlight DocSearch Typesense collection name.
TYPESENSE_COLLECTION_NAME=docs

# Production defaults to the Cloudflare Pages Function proxy.
# Set to false only if you intentionally want browser-to-Typesense direct search.
TYPESENSE_USE_PROXY=true
TYPESENSE_PROXY_PATH=/typesense
# Optional full browser endpoint override.
# TYPESENSE_SEARCH_ENDPOINT=https://word.lovejade.cn/typesense

# Browser-side placeholder key used only when TYPESENSE_USE_PROXY=true.
# The Cloudflare proxy strips this and injects TYPESENSE_SEARCH_API_KEY server-side.
TYPESENSE_PROXY_CLIENT_API_KEY=proxy-search

# Runtime env for the Cloudflare Pages Function.
# This must be a search-only key scoped to documents:search on the docs collection.
TYPESENSE_ORIGIN=https://typesense.yuxuanda.cn
TYPESENSE_SEARCH_API_KEY=replace-with-search-only-key
TYPESENSE_PROXY_ALLOWED_ORIGINS=https://word.lovejade.cn

# Direct local search mode:
# TYPESENSE_USE_PROXY=false
# TYPESENSE_NODE_URL=https://typesense.yuxuanda.cn
# TYPESENSE_SEARCH_API_KEY=replace-with-search-only-key

# Indexing/scraper key, if needed by local scripts.
# Never expose a bootstrap/admin/write key in astro.config.mjs or PUBLIC_* vars.
TYPESENSE_API_KEY=replace-with-admin-or-indexing-key
